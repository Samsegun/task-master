# ─── .env.docker.example ───────────────────────────────────────────
# Copy this file to .env.docker and fill in your actual values
# NEVER commit the real .env.docker file to version control
# ───────────────────────────────────────────────────────────────────

ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL="postgresql://USER:PASSWORD@database:5432/taskmaster"
DIRECT_URL="postgresql://USER:PASSWORD@database:5432/taskmaster"
PORT=7000
NODE_ENV=docker

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_INVITATION_SECRET=

JWT_ACCESS_EXPIRATION=
JWT_REFRESH_EXPIRATION=
JWT_INVITATION_EXPIRATION=
REFRESH_PASSWORD_EXPIRATION=

FRONTEND_URL=http://localhost:5173
APP_DEBUG=false
SWAGGER_BASE_URL=

# Email (use Ethereal for dev: https://ethereal.email)
SMTP_SERVICE=""
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL="taskmaster@support.com"

# postgres credentials for Docker
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=taskmaster
