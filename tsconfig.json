{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "ignoreDeprecations": "5.0",
        "outDir": "dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "types": ["node", "jest", "@types/jest", "@prisma/client"]
    },
    "include": ["src/**/*", "prisma/**/*"],
    "exclude": ["node_modules", "dist"],
    "ts-node": {
        "files": true
    }
}
